# Copy this file to .env and fill in your values
# Never commit the real .env to git

# Your Home Assistant MQTT broker IP
MQTT_HOST=192.168.x.x

# MQTT credentials (same ones used in your Frigate .env)
MQTT_USER=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# Frigate URL — use the internal HTTP port, not HTTPS
FRIGATE_URL=http://192.168.x.x:5000

# Camera name exactly as defined in Frigate config.yml
CAMERA_NAME=living_room

# Detection frame dimensions — must match detect: width/height in Frigate config.yml
DETECT_FRAME_WIDTH=640
DETECT_FRAME_HEIGHT=480
